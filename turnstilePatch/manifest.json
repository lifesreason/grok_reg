{
    "manifest_version": 2,
    "name": "Turnstile Patch",
    "version": "1.1.0",
    "description": "Light stealth for Cloudflare Turnstile without early API patching",
    "content_scripts": [
        {
            "matches": [
                "*://accounts.x.ai/*",
                "*://auth.x.ai/*",
                "*://grok.com/*",
                "*://*.grok.com/*",
                "*://challenges.cloudflare.com/*"
            ],
            "js": ["content.js"],
            "run_at": "document_start",
            "all_frames": true
        }
    ],
    "permissions": ["activeTab"],
    "web_accessible_resources": ["pageHook.js"]
}
